CC = gcc
CFLAGS = -Wall -Wextra -Werror -std=c11 -g
LDFLAGS = -lm

ALL_FILES = $(shell find . -regex ".*\.[ch]")

.PHONY: all clean test run-tests fmt check_fmt

all: run-tests

quadratic_test: quadratic_test.c quadratic.c quadratic.h
	$(CC) $(CFLAGS) -o $@ $< quadratic.c $(LDFLAGS)

integr_test: task5/src/test5.c task5/src/integr.c task5/include/integr.h
	$(CC) $(CFLAGS) -Itask5/include -o $@ $< task5/src/integr.c $(LDFLAGS)

stack_test: task7/src/test.c task7/src/stack.c task7/include/stack.h
	$(CC) $(CFLAGS) -Itask7/include -o $@ $< task7/src/stack.c

test: quadratic_test integr_test stack_test

run-tests: test
	@echo "=== Running Quadratic Test ==="
	./quadratic_test
	@echo "=== Running Integral Test ==="
	./integr_test
	@echo "=== Running Stack Test ==="
	./stack_test
	@echo "=== All tests passed! ==="

check_fmt:
	@clang-format -style=LLVM --dry-run --Werror $(ALL_FILES)

fmt:
	@clang-format -style=LLVM -i $(ALL_FILES)

clean:
	rm -f quadratic_test integr_test stack_test *.o *.a *.out
