clear:
	rm -rf *.o *.a *_test

check_fmt:
	clang-format -style=LLVM --dry-run --Werror $$(find . -name "*.c" -o -name "*.h")

fmt:
	clang-format -style=LLVM -i $$(find . -name "*.c" -o -name "*.h")

# --- task4
task4.o: task4/include/task4.h task4/src/task4.c
	gcc -g -c task4/src/task4.c -o task4.o

task4.a: task4.o
	ar rc task4.a task4.o

task4_test.o: task4/src/test.c
	gcc -g -c task4/src/test.c -o task4_test.o

task4_test: task4_test.o task4.a
	gcc -g -static -o task4_test task4_test.o task4.a

