CC = gcc
CFLAGS = -std=c11 - Wall - Wextra - Werror

SRCS = $(wildcard *.c)
TEST_SRCS = $(wildcard *_test.c)
TEST_BINS = $(TEST_SRCS:.c=)

.PHONY: all clean fmt fmt-check test

all: $(TEST_BINS)

%: %.c
        $(CC) $(CFLAGS) -o $@ $<

test: $(TEST_BINS)
        @for t in $(TEST_BINS); do \
                echo "Running $$t..."; \
                ./$$t; \
        done

fmt: 
        clang-format -i $(SRCS)

fmt-check:
        clang-format --dry-run --Werror $(SRCS)

clean:
        rm -f $(TEST_BINS)

